AoB,OAAM;AAAA,cAAA;;;;;;+XAgBtBC,cAAA,SAAAC,MAAA,IAAA,EAAK,cAAc,wZAUnBC,sBAAA,MAAA,QAAAD,MAAA,IAAA,EAAK,IAAI,IAATE,gBAAAF,MAAA,IAAA,EAAK,MAAI,MAAA,IAATG,cAAAH,MAAA,IAAA,EAAK,MAAI,MAAA,CAAA,IAAA,cAAA,0CAATC,sBAAA,MAAA,QAAAD,MAAA,IAAA,EAAK,IAAI,IAATE,gBAAAF,MAAA,IAAA,EAAK,MAAI,SAAA,IAATG,cAAAH,MAAA,IAAA,EAAK,MAAI,SAAA,CAAA,IAAA,cAAA,iDAATC,sBAAA,MAAA,QAAAD,MAAA,IAAA,EAAK,IAAI,IAATE,gBAAAF,MAAA,IAAA,EAAK,MAAI,aAAA,IAATG,cAAAH,MAAA,IAAA,EAAK,MAAI,aAAA,CAAA,IAAA,cAAA,iDAATC,sBAAA,MAAA,QAAAD,MAAA,IAAA,EAAK,IAAI,IAATE,gBAAAF,MAAA,IAAA,EAAK,MAAI,SAAA,IAATG,cAAAH,MAAA,IAAA,EAAK,MAAI,SAAA,CAAA,IAAA,cAAA,6CAATC,sBAAA,MAAA,QAAAD,MAAA,IAAA,EAAK,IAAI,IAATE,gBAAAF,MAAA,IAAA,EAAK,MAAI,SAAA,IAATG,cAAAH,MAAA,IAAA,EAAK,MAAI,SAAA,CAAA,IAAA,cAAA,oDAATC,sBAAA,MAAA,QAAAD,MAAA,IAAA,EAAK,IAAI,IAATE,gBAAAF,MAAA,IAAA,EAAK,MAAI,OAAA,IAATG,cAAAH,MAAA,IAAA,EAAK,MAAI,OAAA,CAAA,IAAA,cAAA,mQAeTC,sBAAA,MAAA,QAAAD,MAAA,IAAA,EAAK,OAAO,IAAZE,gBAAAF,MAAA,IAAA,EAAK,SAAO,EAAA,IAAZG,cAAAH,MAAA,IAAA,EAAK,SAAO,EAAA,CAAA,IAAA,cAAA;AAKKI,oBAAAJ,MAAA,SAAA,IAAX,YAAO;sCAAkC,SAAO,QAAQ,EAAE,IALhEC,sBAAA,MAAA,QAAAD,MAAA,IAAA,EAAK,OAAO,IAAZE,gBAAAF,MAAA,IAAA,EAAK,SAKiD,QAAQ,EAAE,IALhEG,cAAAH,MAAA,IAAA,EAAK,SAKiD,QAAQ,EAAE,CAAA,IAAA,cAAA,MACpEK,eAAA,QAAQ,IAAI;;4KAWLJ,sBAAA,CAAAD,MAAA,IAAA,EAAK,OAAO,IAAA,cAAA,8JADfC,sBAAA,MAAA,QAAAD,MAAA,IAAA,EAAK,KAAK,IAAVE,gBAAAF,MAAA,IAAA,EAAK,OAAK,EAAA,IAAVG,cAAAH,MAAA,IAAA,EAAK,OAAK,EAAA,CAAA,IAAA,cAAA,MAICK,eAAAL,MAAA,IAAA,EAAK,UAAO,iBAAA,sBAAA;AACRI,oBAAAJ,MAAA,cAAA,IAAT,UAAK;sCAAqC,SAAO,MAAM,EAAE,IAL/DC,sBAAA,MAAA,QAAAD,MAAA,IAAA,EAAK,KAAK,IAAVE,gBAAAF,MAAA,IAAA,EAAK,OAKkD,MAAM,EAAE,IAL/DG,cAAAH,MAAA,IAAA,EAAK,OAKkD,MAAM,EAAE,CAAA,IAAA,cAAA,MACnEK,eAAA,MAAM,YAAY,sBAAS,eAAe,MAAM,WAAW,CAAA;;;AAGzD,UAAAL,MAAA,IAAA,EAAK,OAAK;;;;;2GAORD,cAAA,SAAAC,MAAA,IAAA,EAAK,YAAY,sOASjBD,cAAA,SAAAC,MAAA,IAAA,EAAK,QAAQ,yWAgBbD,cAAA,SAAAC,MAAA,IAAA,EAAK,YAAY,wOASjBD,cAAA,SAAAC,MAAA,IAAA,EAAK,UAAU;;QAkBpB,MAAK;AAAA,QAAc,OAAM;AAAA,MAAA;;AAMJI,oBAAAJ,MAAA,IAAA,EAAK,OAAK,CAA1B,MAAM,UAAK;0MAITD,cAAA,SAAA,KAAK,WAAW,iRAUTA,cAAA,SAAA,KAAK,QAAQ,6QAWbA,cAAA,SAAA,KAAK,UAAU,gUAWAM,eAAA,eAAe,KAAK,WAAW,KAAK,UAAU,CAAA;YAErEL,MAAA,IAAA,EAAK,MAAM,SAAM,GAAA;;;YAKjB,MAAK;AAAA,YAAiB,OAAM;AAAA,UAAA;;;;;;;8LAWXK,eAAA,eAAeL,MAAA,QAAA,CAAQ,CAAA,4FAGRK,eAAAL,MAAA,IAAA,EAAK,QAAQ,uCAC5BK,eAAA,eAAeL,MAAA,SAAA,CAAS,CAAA;AAEf,UAAAA,MAAA,IAAA,EAAK,kBAAe,GAAA;+JAEb,eAAeA,MAAA,IAAA,EAAK,eAAe,CAAA,CAAA,eAAA;AAAA;;;qJAI7CK,eAAA,eAAeL,MAAA,KAAA,CAAK,CAAA,yOAYrCD,cAAA,SAAAC,MAAA,IAAA,EAAK,QAAQ,kQAWbD,cAAA,SAAAC,MAAA,IAAA,EAAK,eAAe,0dAY3BK,eAAAL,MAAA,IAAA,EAAK,KAAK,qQASVK,eAAAL,MAAA,IAAA,EAAK,KAAK,8NAmBZA,MAAA,QAAA,CAAQ,IAAA,cAAA,6HAGhBA,MAAA,QAAA,IAAQ,gBAAA,gBAAA;;;;;;;;;;","names":["_withAsyncContext","_ssrRenderAttrs","_mergeProps","_push","_parent","_createVNode","_ssrRenderAttr","_unref","_ssrIncludeBooleanAttr","_ssrLooseContain","_ssrLooseEqual","_ssrRenderList","_ssrInterpolate"],"sources":["../../../../app/pages/admin/billing/create.vue"],"sourcesContent":["<template>\n  <div class=\"space-y-6\">\n    <div class=\"flex items-center gap-4\">\n      <NuxtLink to=\"/admin/billing\" class=\"p-2 hover:bg-muted rounded-full\">\n        <Icon name=\"lucide:arrow-left\" class=\"w-5 h-5\" />\n      </NuxtLink>\n      <div>\n        <h1 class=\"text-3xl font-bold\">Create Invoice</h1>\n        <p class=\"text-muted-foreground\">Generate a new invoice</p>\n      </div>\n    </div>\n\n    <form @submit.prevent=\"createInvoice\" class=\"max-w-5xl space-y-8\">\n      <!-- Basic Information -->\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Invoice Information</h2>\n        <div class=\"grid md:grid-cols-3 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Invoice Number *</label>\n            <input\n              v-model=\"form.invoice_number\"\n              type=\"text\"\n              placeholder=\"INV-2024-001\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Invoice Type *</label>\n            <select\n              v-model=\"form.type\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            >\n              <option value=\"rent\">Rent</option>\n              <option value=\"utility\">Utility</option>\n              <option value=\"maintenance\">Maintenance</option>\n              <option value=\"service\">Service</option>\n              <option value=\"deposit\">Security Deposit</option>\n              <option value=\"other\">Other</option>\n            </select>\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Company *</label>\n            <select\n              v-model=\"form.company\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            >\n              <option value=\"\">Select Company</option>\n              <option v-for=\"company in companies\" :key=\"company.id\" :value=\"company.id\">\n                {{ company.name }}\n              </option>\n            </select>\n          </div>\n        </div>\n\n        <div class=\"grid md:grid-cols-3 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Lease (Optional)</label>\n            <select\n              v-model=\"form.lease\"\n              :disabled=\"!form.company\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary disabled:opacity-50\"\n            >\n              <option value=\"\">{{ form.company ? 'Select Lease' : 'Select company first' }}</option>\n              <option v-for=\"lease in filteredLeases\" :key=\"lease.id\" :value=\"lease.id\">\n                {{ lease.lease_number }} - {{ formatCurrency(lease.rent_amount) }}/month\n              </option>\n            </select>\n            <p v-if=\"form.lease\" class=\"text-xs text-green-600\">\n              Rent amount auto-filled from lease\n            </p>\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Invoice Date *</label>\n            <input\n              v-model=\"form.invoice_date\"\n              type=\"date\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Due Date *</label>\n            <input\n              v-model=\"form.due_date\"\n              type=\"date\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n        </div>\n      </div>\n\n      <!-- Billing Period -->\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Billing Period</h2>\n        <div class=\"grid md:grid-cols-2 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Period Start *</label>\n            <input\n              v-model=\"form.period_start\"\n              type=\"date\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Period End *</label>\n            <input\n              v-model=\"form.period_end\"\n              type=\"date\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n        </div>\n      </div>\n\n      <!-- Invoice Items -->\n      <div class=\"space-y-4\">\n        <div class=\"flex items-center justify-between\">\n          <h2 class=\"text-xl font-semibold\">Invoice Items</h2>\n          <button \n            type=\"button\"\n            @click=\"addItem\"\n            class=\"flex items-center gap-2 px-3 py-1.5 text-sm border border-border rounded-lg hover:bg-muted\"\n          >\n            <Icon name=\"lucide:plus\" class=\"w-4 h-4\" />\n            Add Item\n          </button>\n        </div>\n\n        <div class=\"space-y-3\">\n          <div v-for=\"(item, index) in form.items\" :key=\"index\" class=\"grid md:grid-cols-12 gap-3 items-start p-4 border border-border rounded-lg\">\n            <div class=\"md:col-span-5 space-y-2\">\n              <label class=\"text-sm font-medium\">Description</label>\n              <input\n                v-model=\"item.description\"\n                type=\"text\"\n                placeholder=\"Item description\"\n                class=\"w-full px-3 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n                required\n              />\n            </div>\n            <div class=\"md:col-span-2 space-y-2\">\n              <label class=\"text-sm font-medium\">Quantity</label>\n              <input\n                v-model.number=\"item.quantity\"\n                type=\"number\"\n                step=\"0.01\"\n                min=\"0.01\"\n                class=\"w-full px-3 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n                required\n              />\n            </div>\n            <div class=\"md:col-span-3 space-y-2\">\n              <label class=\"text-sm font-medium\">Unit Price</label>\n              <input\n                v-model.number=\"item.unit_price\"\n                type=\"number\"\n                step=\"0.01\"\n                min=\"0\"\n                class=\"w-full px-3 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n                required\n              />\n            </div>\n            <div class=\"md:col-span-2 space-y-2\">\n              <label class=\"text-sm font-medium\">Total</label>\n              <div class=\"flex items-center gap-2\">\n                <p class=\"font-medium py-2\">{{ formatCurrency(item.quantity * item.unit_price) }}</p>\n                <button \n                  v-if=\"form.items.length > 1\"\n                  type=\"button\"\n                  @click=\"removeItem(index)\"\n                  class=\"p-2 text-red-500 hover:bg-red-50 rounded-lg\"\n                >\n                  <Icon name=\"lucide:trash-2\" class=\"w-4 h-4\" />\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Totals -->\n        <div class=\"bg-muted/50 rounded-lg p-4 space-y-2\">\n          <div class=\"flex justify-between\">\n            <span class=\"text-muted-foreground\">Subtotal</span>\n            <span class=\"font-medium\">{{ formatCurrency(subtotal) }}</span>\n          </div>\n          <div class=\"flex justify-between\">\n            <span class=\"text-muted-foreground\">GST ({{ form.gst_rate }}%)</span>\n            <span class=\"font-medium\">{{ formatCurrency(taxAmount) }}</span>\n          </div>\n          <div class=\"flex justify-between\" v-if=\"form.discount_amount > 0\">\n            <span class=\"text-muted-foreground\">Discount</span>\n            <span class=\"font-medium text-green-600\">-{{ formatCurrency(form.discount_amount) }}</span>\n          </div>\n          <div class=\"flex justify-between pt-2 border-t border-border\">\n            <span class=\"font-semibold\">Total</span>\n            <span class=\"text-xl font-bold\">{{ formatCurrency(total) }}</span>\n          </div>\n        </div>\n      </div>\n\n      <!-- Additional Settings -->\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Additional Settings</h2>\n        <div class=\"grid md:grid-cols-3 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">GST Rate (%)</label>\n            <input\n              v-model.number=\"form.gst_rate\"\n              type=\"number\"\n              step=\"0.01\"\n              min=\"0\"\n              max=\"100\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Discount Amount</label>\n            <input\n              v-model.number=\"form.discount_amount\"\n              type=\"number\"\n              step=\"0.01\"\n              min=\"0\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n        </div>\n        <div class=\"grid md:grid-cols-2 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Terms & Conditions</label>\n            <textarea\n              v-model=\"form.terms\"\n              rows=\"3\"\n              placeholder=\"Payment terms, late fees, etc.\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Notes</label>\n            <textarea\n              v-model=\"form.notes\"\n              rows=\"3\"\n              placeholder=\"Additional notes...\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"flex items-center gap-4 pt-4\">\n        <button \n          type=\"button\"\n          @click=\"$router.back()\"\n          class=\"px-4 py-2 border border-border rounded-lg hover:bg-muted\"\n        >\n          Cancel\n        </button>\n        <button \n          type=\"submit\"\n          :disabled=\"creating\"\n          class=\"px-4 py-2 bg-primary text-primary-foreground rounded-lg hover:bg-primary/90 disabled:opacity-50\"\n        >\n          {{ creating ? 'Creating...' : 'Create Invoice' }}\n        </button>\n      </div>\n    </form>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefinePageMeta({\n  layout: 'admin',\n  middleware: ['auth'],\n})\n\nconst { authHeaders } = useAuth()\nconst API_BASE = 'http://localhost:8000/api'\n\nconst creating = ref(false)\n\nconst form = ref({\n  invoice_number: '',\n  company: '',\n  lease: '',\n  type: 'rent',\n  period_start: '',\n  period_end: '',\n  invoice_date: new Date().toISOString().split('T')[0],\n  due_date: '',\n  gst_rate: 18.00,\n  discount_amount: 0,\n  status: 'draft',\n  notes: '',\n  terms: 'Payment due within 30 days. Late payments subject to 2% monthly interest.',\n  items: [\n    { description: '', quantity: 1, unit_price: 0 }\n  ]\n})\n\n// Fetch companies and leases for dropdowns\nconst { data: companies } = await useFetch(`${API_BASE}/companies/`, {\n  headers: authHeaders()\n})\n\nconst { data: leases } = await useFetch(`${API_BASE}/leases/`, {\n  headers: authHeaders()\n})\n\n// Filter leases by selected company\nconst filteredLeases = computed(() => {\n  if (!form.value.company) return leases.value || []\n  return (leases.value || []).filter((lease: any) => lease.company === parseInt(form.value.company))\n})\n\n// Auto-fill rent amount when lease is selected\nwatch(() => form.value.lease, (newLeaseId) => {\n  if (newLeaseId) {\n    const selectedLease = (leases.value || []).find((l: any) => l.id === parseInt(newLeaseId))\n    if (selectedLease && selectedLease.rent_amount) {\n      // Update first item with rent details\n      form.value.items[0] = {\n        description: `Rent for ${selectedLease.lease_number}`,\n        quantity: 1,\n        unit_price: selectedLease.rent_amount\n      }\n      // Auto-fill company if not already set\n      if (!form.value.company) {\n        form.value.company = selectedLease.company\n      }\n    }\n  }\n})\n\n// Calculate totals\nconst subtotal = computed(() => {\n  return form.value.items.reduce((sum: number, item: any) => {\n    return sum + (item.quantity * item.unit_price)\n  }, 0)\n})\n\nconst taxAmount = computed(() => {\n  return subtotal.value * (form.value.gst_rate / 100)\n})\n\nconst total = computed(() => {\n  return subtotal.value + taxAmount.value - form.value.discount_amount\n})\n\nconst addItem = () => {\n  form.value.items.push({ description: '', quantity: 1, unit_price: 0 })\n}\n\nconst removeItem = (index: number) => {\n  form.value.items.splice(index, 1)\n}\n\nconst formatCurrency = (value: number) => {\n  return new Intl.NumberFormat('en-IN', {\n    style: 'currency',\n    currency: 'INR',\n    maximumFractionDigits: 2,\n  }).format(value || 0)\n}\n\nconst createInvoice = async () => {\n  creating.value = true\n  try {\n    await $fetch(`${API_BASE}/billing/invoices/`, {\n      method: 'POST',\n      headers: authHeaders(),\n      body: form.value\n    })\n    \n    navigateTo('/admin/billing')\n  } catch (e: any) {\n    if (e.data) {\n      const errors = Object.entries(e.data)\n        .map(([key, msgs]) => `${key}: ${Array.isArray(msgs) ? msgs.join(', ') : msgs}`)\n        .join('\\n')\n      alert(`Failed to create invoice:\\n${errors}`)\n    } else {\n      alert('Failed to create invoice')\n    }\n  } finally {\n    creating.value = false\n  }\n}\n</script>\n"],"version":3}