,QAAAP,MAAA,QAAA,EAAS,IAAI,IAAbQ,gBAAAR,MAAA,QAAA,EAAS,MAAI,cAAA,IAAbS,cAAAT,MAAA,QAAA,EAAS,MAAI,cAAA,CAAA,IAAA,cAAA,yDAAbO,sBAAA,MAAA,QAAAP,MAAA,QAAA,EAAS,IAAI,IAAbQ,gBAAAR,MAAA,QAAA,EAAS,MAAI,gBAAA,IAAbS,cAAAT,MAAA,QAAA,EAAS,MAAI,gBAAA,CAAA,IAAA,cAAA,qDAAbO,sBAAA,MAAA,QAAAP,MAAA,QAAA,EAAS,IAAI,IAAbQ,gBAAAR,MAAA,QAAA,EAAS,MAAI,UAAA,IAAbS,cAAAT,MAAA,QAAA,EAAS,MAAI,UAAA,CAAA,IAAA,cAAA,8QAcbO,sBAAA,MAAA,QAAAP,MAAA,QAAA,EAAS,cAAc,IAAvBQ,gBAAAR,MAAA,QAAA,EAAS,gBAAc,WAAA,IAAvBS,cAAAT,MAAA,QAAA,EAAS,gBAAc,WAAA,CAAA,IAAA,cAAA,gDAAvBO,sBAAA,MAAA,QAAAP,MAAA,QAAA,EAAS,cAAc,IAAvBQ,gBAAAR,MAAA,QAAA,EAAS,gBAAc,UAAA,IAAvBS,cAAAT,MAAA,QAAA,EAAS,gBAAc,UAAA,CAAA,IAAA,cAAA,kDAAvBO,sBAAA,MAAA,QAAAP,MAAA,QAAA,EAAS,cAAc,IAAvBQ,gBAAAR,MAAA,QAAA,EAAS,gBAAc,aAAA,IAAvBS,cAAAT,MAAA,QAAA,EAAS,gBAAc,aAAA,CAAA,IAAA,cAAA,kDAAvBO,sBAAA,MAAA,QAAAP,MAAA,QAAA,EAAS,cAAc,IAAvBQ,gBAAAR,MAAA,QAAA,EAAS,gBAAc,UAAA,IAAvBS,cAAAT,MAAA,QAAA,EAAS,gBAAc,UAAA,CAAA,IAAA,cAAA,mQAmBhBK,cAAA,SAAAL,MAAA,QAAA,EAAS,KAAK,2OASdK,cAAA,SAAAL,MAAA,QAAA,EAAS,IAAI,+OASbK,cAAA,SAAAL,MAAA,QAAA,EAAS,QAAQ,kWAcjBK,cAAA,SAAAL,MAAA,QAAA,EAAS,SAAS,2OASlBK,cAAA,SAAAL,MAAA,QAAA,EAAS,aAAa,0XAc7BA,MAAA,cAAA,CAAc,iYASdI,eAAAJ,MAAA,QAAA,EAAS,WAAW,8NAkBtBA,MAAA,MAAA,CAAM,IAAA,cAAA,6HAGdA,MAAA,MAAA,IAAM,cAAA,cAAA;;;;;;;;;;;;;;","names":["_withAsyncContext","_ssrRenderAttrs","_mergeProps","_unref","_push","_parent","_createVNode","_ssrInterpolate","_ssrRenderAttr","_ssrRenderList","_ssrIncludeBooleanAttr","_ssrLooseContain","_ssrLooseEqual"],"sources":["../../../../app/pages/admin/spaces/[id]/edit.vue"],"sourcesContent":["<template>\n  <div class=\"space-y-6\">\n    <div class=\"flex items-center gap-4\">\n      <NuxtLink :to=\"`/admin/spaces/${route.params.id}`\" class=\"p-2 hover:bg-muted rounded-full\">\n        <Icon name=\"lucide:arrow-left\" class=\"w-5 h-5\" />\n      </NuxtLink>\n      <div>\n        <h1 class=\"text-3xl font-bold\">Edit Space</h1>\n        <p class=\"text-muted-foreground\">Update info for {{ space?.name }}</p>\n      </div>\n    </div>\n\n    <form @submit.prevent=\"updateSpace\" class=\"max-w-4xl space-y-8\" v-if=\"formData\">\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Basic Information</h2>\n        <div class=\"grid md:grid-cols-2 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Space Code *</label>\n            <input\n              v-model=\"formData.code\"\n              type=\"text\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Space Name *</label>\n            <input\n              v-model=\"formData.name\"\n              type=\"text\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Property *</label>\n            <select\n              v-model=\"formData.property\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            >\n              <option v-for=\"prop in properties\" :key=\"prop.id\" :value=\"prop.id\">\n                {{ prop.name }} ({{ prop.code }})\n              </option>\n            </select>\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Type *</label>\n            <select\n              v-model=\"formData.type\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            >\n              <option value=\"private_office\">Private Office</option>\n              <option value=\"open_desk\">Open Desk</option>\n              <option value=\"meeting_room\">Meeting Room</option>\n              <option value=\"virtual_office\">Virtual Office</option>\n              <option value=\"hot_desk\">Hot Desk</option>\n            </select>\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Status *</label>\n            <select\n              v-model=\"formData.current_status\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            >\n              <option value=\"available\">Available</option>\n              <option value=\"occupied\">Occupied</option>\n              <option value=\"maintenance\">Maintenance</option>\n              <option value=\"reserved\">Reserved</option>\n            </select>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Location & Specifications</h2>\n        <div class=\"grid md:grid-cols-3 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Floor *</label>\n            <input\n              v-model.number=\"formData.floor\"\n              type=\"number\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Area (sqft) *</label>\n            <input\n              v-model.number=\"formData.area\"\n              type=\"number\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Capacity (people)</label>\n            <input\n              v-model.number=\"formData.capacity\"\n              type=\"number\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Pricing</h2>\n        <div class=\"grid md:grid-cols-2 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Base Rent (Monthly) *</label>\n            <input\n              v-model.number=\"formData.base_rent\"\n              type=\"number\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Price Per Day</label>\n            <input\n              v-model.number=\"formData.price_per_day\"\n              type=\"number\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Additional Details</h2>\n        <div class=\"space-y-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Amenities (comma-separated)</label>\n            <input\n              v-model=\"amenitiesInput\"\n              type=\"text\"\n              placeholder=\"WiFi, AC, Projector\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Description</label>\n            <textarea\n              v-model=\"formData.description\"\n              rows=\"3\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"flex items-center gap-4 pt-4\">\n        <button \n          type=\"button\"\n          @click=\"$router.back()\"\n          class=\"px-4 py-2 border border-border rounded-lg hover:bg-muted\"\n        >\n          Cancel\n        </button>\n        <button \n          type=\"submit\"\n          :disabled=\"saving\"\n          class=\"px-4 py-2 bg-primary text-primary-foreground rounded-lg hover:bg-primary/90 disabled:opacity-50\"\n        >\n          {{ saving ? 'Saving...' : 'Save Changes' }}\n        </button>\n      </div>\n    </form>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefinePageMeta({\n  layout: 'admin',\n  middleware: ['auth'],\n})\n\nconst { authHeaders } = useAuth()\nconst API_BASE = 'http://localhost:8000/api/spaces'\nconst PROPERTIES_API = 'http://localhost:8000/api/properties'\n\nconst route = useRoute()\nconst saving = ref(false)\nconst amenitiesInput = ref('')\n\n// Fetch space and properties\nconst { data: space, refresh } = await useFetch(`${API_BASE}/${route.params.id}/`, {\n  headers: authHeaders()\n})\n\nconst { data: properties } = await useFetch(`${PROPERTIES_API}/`, {\n  headers: authHeaders()\n})\n\nconst formData = ref(null)\n\n// Initialize form data when space is loaded\nwatchEffect(() => {\n  if (space.value) {\n    formData.value = {\n      code: space.value.code,\n      name: space.value.name,\n      property: space.value.property,\n      type: space.value.type,\n      floor: space.value.floor,\n      area: Number(space.value.area),\n      capacity: space.value.capacity,\n      base_rent: Number(space.value.base_rent),\n      price_per_day: space.value.price_per_day ? Number(space.value.price_per_day) : null,\n      current_status: space.value.current_status,\n      description: space.value.description || '',\n    }\n    amenitiesInput.value = space.value.amenities?.join(', ') || ''\n  }\n})\n\nconst updateSpace = async () => {\n  saving.value = true\n  try {\n    const payload = {\n      code: formData.value.code,\n      name: formData.value.name,\n      property: formData.value.property,\n      type: formData.value.type,\n      floor: formData.value.floor,\n      area: formData.value.area,\n      capacity: formData.value.capacity,\n      base_rent: formData.value.base_rent,\n      price_per_day: formData.value.price_per_day,\n      current_status: formData.value.current_status,\n      description: formData.value.description,\n      amenities: amenitiesInput.value.split(',').map(a => a.trim()).filter(a => a)\n    }\n\n    await $fetch(`${API_BASE}/${route.params.id}/`, {\n      method: 'PUT',\n      headers: authHeaders(),\n      body: payload\n    })\n    \n    await refresh()\n    navigateTo(`/admin/spaces/${route.params.id}`)\n  } catch (e: any) {\n    if (e.data) {\n      const errors = Object.entries(e.data)\n        .map(([key, msgs]) => `${key}: ${Array.isArray(msgs) ? msgs.join(', ') : msgs}`)\n        .join('\\n')\n      alert(`Failed to update space:\\n${errors}`)\n    } else {\n      alert('Failed to update space')\n    }\n  } finally {\n    saving.value = false\n  }\n}\n</script>\n"],"version":3}