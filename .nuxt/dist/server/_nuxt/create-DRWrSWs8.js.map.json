"_createVNode","_ssrRenderAttr","_unref","_ssrIncludeBooleanAttr","_ssrLooseContain","_ssrLooseEqual","_ssrInterpolate"],"sources":["../../../../app/pages/admin/companies/create.vue"],"sourcesContent":["<template>\n  <div class=\"space-y-6\">\n    <div class=\"flex items-center gap-4\">\n      <NuxtLink to=\"/admin/companies\" class=\"p-2 hover:bg-muted rounded-full\">\n        <Icon name=\"lucide:arrow-left\" class=\"w-5 h-5\" />\n      </NuxtLink>\n      <div>\n        <h1 class=\"text-3xl font-bold\">Add Company</h1>\n        <p class=\"text-muted-foreground\">Register a new tenant company</p>\n      </div>\n    </div>\n\n    <form @submit.prevent=\"createCompany\" class=\"max-w-4xl space-y-8\">\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Basic Information</h2>\n        <div class=\"grid md:grid-cols-2 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Company Name *</label>\n            <input\n              v-model=\"form.name\"\n              type=\"text\"\n              placeholder=\"TechCorp Solutions\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Legal Name</label>\n            <input\n              v-model=\"form.legal_name\"\n              type=\"text\"\n              placeholder=\"TechCorp Solutions Pvt Ltd\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Company Type *</label>\n            <select\n              v-model=\"form.type\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            >\n              <option value=\"pvt_ltd\">Private Limited</option>\n              <option value=\"llp\">LLP</option>\n              <option value=\"partnership\">Partnership</option>\n              <option value=\"proprietorship\">Proprietorship</option>\n              <option value=\"public_ltd\">Public Limited</option>\n            </select>\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Industry</label>\n            <input\n              v-model=\"form.industry\"\n              type=\"text\"\n              placeholder=\"Information Technology\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Registration Details</h2>\n        <div class=\"grid md:grid-cols-3 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">GSTIN</label>\n            <input\n              v-model=\"form.gstin\"\n              type=\"text\"\n              placeholder=\"27AABCU9603R1ZX\"\n              maxlength=\"15\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">PAN</label>\n            <input\n              v-model=\"form.pan\"\n              type=\"text\"\n              placeholder=\"AABCU9603R\"\n              maxlength=\"10\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">CIN</label>\n            <input\n              v-model=\"form.cin\"\n              type=\"text\"\n              placeholder=\"U72200MH2000PTC123456\"\n              maxlength=\"21\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Location</h2>\n        <div class=\"grid md:grid-cols-2 gap-4\">\n          <div class=\"space-y-2 md:col-span-2\">\n            <label class=\"text-sm font-medium\">Address</label>\n            <input\n              v-model=\"form.address\"\n              type=\"text\"\n              placeholder=\"Full address\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">City</label>\n            <input\n              v-model=\"form.city\"\n              type=\"text\"\n              placeholder=\"Mumbai\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">State</label>\n            <input\n              v-model=\"form.state\"\n              type=\"text\"\n              placeholder=\"Maharashtra\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">PIN Code</label>\n            <input\n              v-model=\"form.pincode\"\n              type=\"text\"\n              placeholder=\"400001\"\n              maxlength=\"6\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Contact Information</h2>\n        <div class=\"grid md:grid-cols-3 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Email</label>\n            <input\n              v-model=\"form.email\"\n              type=\"email\"\n              placeholder=\"contact@company.com\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Phone</label>\n            <input\n              v-model=\"form.phone\"\n              type=\"text\"\n              placeholder=\"+91 98765 43210\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Website</label>\n            <input\n              v-model=\"form.website\"\n              type=\"url\"\n              placeholder=\"https://www.company.com\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Additional Details</h2>\n        <div class=\"grid md:grid-cols-2 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Credit Score (0-100)</label>\n            <input\n              v-model.number=\"form.credit_score\"\n              type=\"number\"\n              min=\"0\"\n              max=\"100\"\n              placeholder=\"75\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2 md:col-span-2\">\n            <label class=\"text-sm font-medium\">Notes</label>\n            <textarea\n              v-model=\"form.notes\"\n              rows=\"3\"\n              placeholder=\"Additional notes about the company...\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"flex items-center gap-4 pt-4\">\n        <button \n          type=\"button\"\n          @click=\"$router.back()\"\n          class=\"px-4 py-2 border border-border rounded-lg hover:bg-muted\"\n        >\n          Cancel\n        </button>\n        <button \n          type=\"submit\"\n          :disabled=\"creating\"\n          class=\"px-4 py-2 bg-primary text-primary-foreground rounded-lg hover:bg-primary/90 disabled:opacity-50\"\n        >\n          {{ creating ? 'Creating...' : 'Create Company' }}\n        </button>\n      </div>\n    </form>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefinePageMeta({\n  layout: 'admin',\n  middleware: ['auth'],\n})\n\nconst { authHeaders } = useAuth()\nconst API_BASE = 'http://localhost:8000/api/companies'\n\nconst creating = ref(false)\n\nconst form = ref({\n  name: '',\n  legal_name: '',\n  type: 'pvt_ltd',\n  industry: '',\n  gstin: '',\n  pan: '',\n  cin: '',\n  address: '',\n  city: '',\n  state: '',\n  pincode: '',\n  email: '',\n  phone: '',\n  website: '',\n  credit_score: 0,\n  notes: '',\n})\n\nconst createCompany = async () => {\n  creating.value = true\n  try {\n    const payload = {\n      ...form.value,\n      status: 'active'\n    }\n\n    await $fetch(`${API_BASE}/`, {\n      method: 'POST',\n      headers: authHeaders(),\n      body: payload\n    })\n    \n    navigateTo('/admin/companies')\n  } catch (e: any) {\n    if (e.data) {\n      const errors = Object.entries(e.data)\n        .map(([key, msgs]) => `${key}: ${Array.isArray(msgs) ? msgs.join(', ') : msgs}`)\n        .join('\\n')\n      alert(`Failed to create company:\\n${errors}`)\n    } else {\n      alert('Failed to create company')\n    }\n  } finally {\n    creating.value = false\n  }\n}\n</script>\n"],"version":3}