AAA,EAAK,OAK0C,MAAM,EAAE,IALvDG,cAAAH,MAAA,IAAA,EAAK,OAK0C,MAAM,EAAE,CAAA,IAAA,cAAA,MAC3DK,eAAA,MAAM,IAAI,OAASA,eAAA,MAAM,IAAI;;sPAazBN,cAAA,SAAAC,MAAA,IAAA,EAAK,UAAU,sOASfD,cAAA,SAAAC,MAAA,IAAA,EAAK,QAAQ,gXAeND,cAAA,SAAAC,MAAA,IAAA,EAAK,WAAW,4RAYhBD,cAAA,SAAAC,MAAA,IAAA,EAAK,gBAAgB,wRAWrBD,cAAA,SAAAC,MAAA,IAAA,EAAK,uBAAuB,uRAY5BD,cAAA,SAAAC,MAAA,IAAA,EAAK,kBAAkB,iYAgB9BD,cAAA,SAAAC,MAAA,IAAA,EAAK,YAAY,kbASjBK,eAAAL,MAAA,IAAA,EAAK,KAAK,8NAmBZA,MAAA,QAAA,CAAQ,IAAA,cAAA,6HAGhBA,MAAA,QAAA,IAAQ,gBAAA,cAAA;;;;;;;;;;","names":["_withAsyncContext","_ssrRenderAttrs","_mergeProps","_push","_parent","_createVNode","_ssrRenderAttr","_unref","_ssrIncludeBooleanAttr","_ssrLooseContain","_ssrLooseEqual","_ssrRenderList","_ssrInterpolate"],"sources":["../../../../app/pages/admin/leases/create.vue"],"sourcesContent":["<template>\n  <div class=\"space-y-6\">\n    <div class=\"flex items-center gap-4\">\n      <NuxtLink to=\"/admin/leases\" class=\"p-2 hover:bg-muted rounded-full\">\n        <Icon name=\"lucide:arrow-left\" class=\"w-5 h-5\" />\n      </NuxtLink>\n      <div>\n        <h1 class=\"text-3xl font-bold\">Create Lease</h1>\n        <p class=\"text-muted-foreground\">Create a new lease agreement</p>\n      </div>\n    </div>\n\n    <form @submit.prevent=\"createLease\" class=\"max-w-4xl space-y-8\">\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Basic Information</h2>\n        <div class=\"grid md:grid-cols-2 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Lease Number *</label>\n            <input\n              v-model=\"form.lease_number\"\n              type=\"text\"\n              placeholder=\"L-2024-001\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Lease Type *</label>\n            <select\n              v-model=\"form.type\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            >\n              <option value=\"lease\">Lease</option>\n              <option value=\"license\">License</option>\n              <option value=\"coworking_membership\">Co-working Membership</option>\n            </select>\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Company *</label>\n            <select\n              v-model=\"form.company\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            >\n              <option value=\"\">Select Company</option>\n              <option v-for=\"company in companies\" :key=\"company.id\" :value=\"company.id\">\n                {{ company.name }}\n              </option>\n            </select>\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Space *</label>\n            <select\n              v-model=\"form.space\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            >\n              <option value=\"\">Select Space</option>\n              <option v-for=\"space in spaces\" :key=\"space.id\" :value=\"space.id\">\n                {{ space.code }} - {{ space.name }}\n              </option>\n            </select>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Lease Dates</h2>\n        <div class=\"grid md:grid-cols-2 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Start Date *</label>\n            <input\n              v-model=\"form.start_date\"\n              type=\"date\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">End Date *</label>\n            <input\n              v-model=\"form.end_date\"\n              type=\"date\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Financial Terms</h2>\n        <div class=\"grid md:grid-cols-2 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Monthly Rent (INR) *</label>\n            <input\n              v-model.number=\"form.rent_amount\"\n              type=\"number\"\n              min=\"0\"\n              step=\"0.01\"\n              placeholder=\"50000\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n              required\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Security Deposit (INR)</label>\n            <input\n              v-model.number=\"form.security_deposit\"\n              type=\"number\"\n              min=\"0\"\n              step=\"0.01\"\n              placeholder=\"100000\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Annual Rent Escalation (%)</label>\n            <input\n              v-model.number=\"form.rent_escalation_percent\"\n              type=\"number\"\n              min=\"0\"\n              max=\"100\"\n              step=\"0.01\"\n              placeholder=\"5\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Notice Period (Days)</label>\n            <input\n              v-model.number=\"form.notice_period_days\"\n              type=\"number\"\n              min=\"0\"\n              placeholder=\"30\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"space-y-4\">\n        <h2 class=\"text-xl font-semibold\">Additional Information</h2>\n        <div class=\"grid md:grid-cols-2 gap-4\">\n          <div class=\"space-y-2\">\n            <label class=\"text-sm font-medium\">Document URL</label>\n            <input\n              v-model=\"form.document_url\"\n              type=\"url\"\n              placeholder=\"https://...\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n          <div class=\"space-y-2 md:col-span-2\">\n            <label class=\"text-sm font-medium\">Notes</label>\n            <textarea\n              v-model=\"form.notes\"\n              rows=\"3\"\n              placeholder=\"Additional notes about the lease...\"\n              class=\"w-full px-4 py-2 bg-card border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-primary\"\n            />\n          </div>\n        </div>\n      </div>\n\n      <div class=\"flex items-center gap-4 pt-4\">\n        <button \n          type=\"button\"\n          @click=\"$router.back()\"\n          class=\"px-4 py-2 border border-border rounded-lg hover:bg-muted\"\n        >\n          Cancel\n        </button>\n        <button \n          type=\"submit\"\n          :disabled=\"creating\"\n          class=\"px-4 py-2 bg-primary text-primary-foreground rounded-lg hover:bg-primary/90 disabled:opacity-50\"\n        >\n          {{ creating ? 'Creating...' : 'Create Lease' }}\n        </button>\n      </div>\n    </form>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefinePageMeta({\n  layout: 'admin',\n  middleware: ['auth'],\n})\n\nconst { authHeaders } = useAuth()\nconst API_BASE = 'http://localhost:8000/api'\n\nconst creating = ref(false)\n\nconst form = ref({\n  lease_number: '',\n  company: '',\n  space: '',\n  type: 'lease',\n  start_date: '',\n  end_date: '',\n  rent_amount: 0,\n  security_deposit: 0,\n  rent_escalation_percent: 0,\n  notice_period_days: 30,\n  status: 'draft',\n  document_url: '',\n  notes: '',\n})\n\n// Fetch companies and spaces for dropdowns\nconst { data: companies } = await useFetch(`${API_BASE}/companies/`, {\n  headers: authHeaders()\n})\n\nconst { data: spaces } = await useFetch(`${API_BASE}/spaces/`, {\n  headers: authHeaders()\n})\n\nconst createLease = async () => {\n  creating.value = true\n  try {\n    await $fetch(`${API_BASE}/leases/`, {\n      method: 'POST',\n      headers: authHeaders(),\n      body: form.value\n    })\n    \n    navigateTo('/admin/leases')\n  } catch (e: any) {\n    if (e.data) {\n      const errors = Object.entries(e.data)\n        .map(([key, msgs]) => `${key}: ${Array.isArray(msgs) ? msgs.join(', ') : msgs}`)\n        .join('\\n')\n      alert(`Failed to create lease:\\n${errors}`)\n    } else {\n      alert('Failed to create lease')\n    }\n  } finally {\n    creating.value = false\n  }\n}\n</script>\n"],"version":3}